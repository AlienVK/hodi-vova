rules_version = '2';
// Правила безопасности Firestore (раздел 12 PRD).
//
// ТЕКУЩИЙ РЕЖИМ: чтение и запись открыты. Данные приложения (шаги, никнеймы,
// короткие сообщения) — низкой чувствительности и по требованию публичности
// видны всем (FR-32). Анонимная аутентификация на бесплатном тарифе включается
// только кнопкой в консоли, поэтому пока запись не привязана к auth.
//
// КАК УСИЛИТЬ (по желанию, ~20 секунд):
//   1. Firebase Console → Build → Authentication → Get started → вкладка
//      Sign-in method → Anonymous → Enable → Save.
//   2. Заменить строку `allow write: if true;` на `allow write: if request.auth != null;`
//      и задеплоить правила заново:  firebase deploy --only firestore:rules
//   Тогда писать в базу сможет только клиент, реально загрузивший приложение.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
