rules_version = '2';
// Правила безопасности Firestore (раздел 12 PRD).
// Чтение — открыто всем (требование публичности FR-32).
// Запись — только для клиента, прошедшего Anonymous Auth (отсекает
// произвольные обращения к API в обход приложения). Прикладная проверка
// логинов/паролей и мастер-пароля выполняется на клиенте.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
